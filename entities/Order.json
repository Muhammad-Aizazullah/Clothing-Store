{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Auto-generated order number"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "shipping_address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "description": "Cart items snapshot",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "price": {
            "type": "number"
          },
          "image_url": {
            "type": "string"
          }
        }
      }
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "Packed",
        "Dispatched",
        "Completed"
      ],
      "default": "Pending"
    },
    "payment_method": {
      "type": "string",
      "default": "COD"
    },
    "is_guest": {
      "type": "boolean",
      "default": false
    },
    "user_id": {
      "type": "string",
      "description": "User ID if logged in"
    }
  },
  "required": [
    "customer_name",
    "customer_phone",
    "shipping_address",
    "city",
    "items",
    "total"
  ]
}